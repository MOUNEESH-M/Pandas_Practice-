# STEP 4: MATHEMATICAL AGGREGATIONS (Calculating metrics)
# =========================================================================
print("\n--- MATHEMATICAL AGGREGATIONS ---")

# Q7: Calculate the average (mean) 'Profit' for all transactions.

print(sales['Profit'].mean()) 

# Q8: Find the maximum (highest) 'Revenue' generated from a single sale in the 'United States'.
print(sales.loc[sales['Country']=='United States','Revenue'].max())
